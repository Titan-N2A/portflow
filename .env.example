# Copier ce fichier en .env et renseigner les valeurs reelles.
# Les variables VITE_* sont exposees cote client (build) — ne pas y mettre
# de secret serveur. Les cles Firebase web sont publiques par nature.

# === Firebase (projet portflow-46738) ===
# console.firebase.google.com -> Parametres -> Vos applications -> Config SDK
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=portflow-46738.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=portflow-46738
VITE_FIREBASE_STORAGE_BUCKET=portflow-46738.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# === TomTom (trafic / itineraires) — developer.tomtom.com ===
VITE_TOMTOM_API_KEY=

# === Groq (IA) — console.groq.com/keys, gratuit sans carte bancaire ===
VITE_GROQ_API_KEY=

# === Google Distance Matrix (trafic, fallback collecte) ===
VITE_GOOGLE_MATRIX_API_KEY=