rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Un utilisateur est admin si son doc users/{uid} existe, role == 'admin'
    // et actif != false. get()/exists() ici sont des lectures internes au
    // moteur de règles : elles ne passent pas par la règle "read" ci-dessous
    // et n'ont donc pas besoin d'un droit de lecture explicite pour l'appelant.
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'public') == 'admin'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('actif', true) != false;
    }

    // ── Collections de configuration PAA (lecture publique, écriture admin) ──
    // Lues sans connexion par le dashboard public ET par scripts/collecte.js
    // (lecture non-authentifiée via clé API) — écrites uniquement depuis
    // AdminPage (services/axesService.js).
    match /flowport_axes/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /flowport_troncons/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /flowport_seuils/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Références horaires recalibrées chaque semaine depuis les relevés
    // réels (scripts/calibrer_references.js via le compte bot admin).
    // Lues sans connexion par la page Graphiques (heatmap, synthèse).
    match /flowport_references/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Agrégats quotidiens par axe/sens (scripts/agreger_quotidien.js via
    // bot) — vues 7 j / 30 j de la page Graphiques à ~180 lectures au
    // lieu des dizaines de milliers de relevés bruts.
    match /agregats_quotidiens/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Données de mesures (lecture dashboard + écriture collecte auto) ────
    // scripts/collecte.js (GitHub Actions, toutes les 5 min) écrit ici via
    // l'API REST Firestore avec une clé API — PAS un token d'utilisateur
    // authentifié (request.auth est null dans ce contexte). Restreindre
    // l'écriture à isAdmin() couperait la collecte live. Pour verrouiller
    // ceci il faudrait migrer collecte.js vers l'Admin SDK + un compte de
    // service (qui contourne ces règles), ce qui est un changement plus
    // large laissé pour une prochaine passe.
    match /mesures/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /mesures_live/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /collecte_auto/{doc} {
      allow read: if true;
      allow write: if true;
    }
    // État anti-spam des alertes email (scripts/notifs.js, non authentifié
    // comme la collecte) — ne contient que niveaux/horodatages, rien de
    // sensible. Même compromis que mesures/collecte_auto ci-dessus.
    match /alertes_etat/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // Non utilisée par le code actuel (services/seed.js n'est appelé nulle
    // part) — verrouillée par précaution, aucun lecteur/écrivain à casser.
    match /references/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Idem : services/troncons.js#createTroncon n'est appelé nulle part.
    // useTroncons.js lit en onSnapshot, donc lecture publique conservée.
    match /troncons/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Registre des rapports générés (page Rapports, connectés) ─────────
    // Métadonnées uniquement (nom, type, période, auteur) — le contenu est
    // régénéré à la demande depuis collecte_auto au téléchargement.
    match /rapports_generes/{doc} {
      allow read, create: if request.auth != null;
      allow delete: if request.auth != null;
      allow update: if false;
    }

    // ── Utilisateurs ──────────────────────────────────────────────────────
    // - Un utilisateur connecté peut lire son propre doc (rôle) : useAuth.js.
    // - Seul un admin peut lister tous les users (AdminPage) ou modifier/
    //   supprimer un doc (updateUser/deleteUserDoc).
    // - La création est ouverte à soi-même (ensureUserDoc, 1re connexion)
    //   MAIS seulement avec role == 'public' : impossible de s'auto-
    //   promouvoir admin en écrivant directement dans Firestore. Un admin
    //   peut créer un doc pour n'importe quel uid avec n'importe quel rôle
    //   (flux normal de création d'utilisateur depuis AdminPage).
    match /users/{uid} {
      allow get:    if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list:   if isAdmin();
      allow create: if request.auth != null &&
                       ((request.auth.uid == uid && request.resource.data.role == 'public') || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ── Config ───────────────────────────────────────────────────────────
    // Non utilisée par le code actuel — verrouillée par précaution.
    match /config/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Positions live utilisateurs (anonymisées) ───────────────────────────
    // Écriture séparée en create/update/delete : sur un delete, request.resource
    // est toujours null (pas de document envoyé), donc "request.resource.data.sessionId"
    // échouerait systématiquement et bloquerait le nettoyage (useGeolocation cleanup()).
    // Lecture publique : les documents ne contiennent qu'un sessionId aléatoire,
    // une position GPS et une vitesse — aucune donnée personnelle identifiante.
    // Nécessaire pour le compteur "usagers actifs" du dashboard public (à la
    // manière de Waze) en plus de la carte de suivi admin.
    match /utilisateurs_live/{sessionId} {
      allow create, update: if request.resource.data.sessionId == sessionId;
      allow delete: if resource.data.sessionId == sessionId;
      allow read: if true;
    }
  }
}
