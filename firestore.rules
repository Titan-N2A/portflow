rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Collections de configuration PAA (lecture publique, écriture admin) ──
    match /flowport_axes/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /flowport_troncons/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /flowport_seuils/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // ── Données de mesures (lecture/écriture collecte auto + dashboard) ──
    match /mesures/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /mesures_live/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /collecte_auto/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /references/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // ── Utilisateurs ──────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow write: if true;
    }

    // ── Config ───────────────────────────────────────────────────────────
    match /config/{doc} {
      allow read: if true;
      allow write: if true;
    }

    // ── Positions live utilisateurs (anonymisées) — visibles admin uniquement ──
    // Écriture séparée en create/update/delete : sur un delete, request.resource
    // est toujours null (pas de document envoyé), donc "request.resource.data.sessionId"
    // échouerait systématiquement et bloquerait le nettoyage (useGeolocation cleanup()).
    match /utilisateurs_live/{sessionId} {
      allow create, update: if request.resource.data.sessionId == sessionId;
      allow delete: if resource.data.sessionId == sessionId;
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
